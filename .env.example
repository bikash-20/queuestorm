# Application
APP_NAME=queuestorm
APP_ENV=production
LOG_LEVEL=INFO
CLASSIFIER_BACKEND=rule_based
MAX_MESSAGE_LENGTH=4000
ALLOWED_ORIGINS=*

# Server
HOST=0.0.0.0
PORT=8000

# Safety
ENFORCE_SAFETY_FILTER=true

# Optional LLM (only used if CLASSIFIER_BACKEND=llm)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=10
